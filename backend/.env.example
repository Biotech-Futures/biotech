# Django core settings
DJANGO_SECRET_KEY=          # generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DEBUG=                      # True for local development, False for production
ALLOWED_HOSTS=              # comma separated e.g. localhost,127.0.0.1

# Database (Azure PostgreSQL)
DB_NAME=                    # database name 
DB_USER=                    # database username
DB_PASSWORD=                # database password
DB_HOST=                    # Azure PostgreSQL server hostname
DB_PORT=                    # default is 5432

# Azure Blob Storage
AZURE_ACCOUNT_NAME=         # Azure storage account name
AZURE_ACCOUNT_KEY=          # Azure storage account access key
AZURE_CONTAINER=            # blob container name e.g. media

# Email (Mailtrap for development)
EMAIL_HOST=                 # SMTP host e.g. sandbox.smtp.mailtrap.io
EMAIL_PORT=                 # SMTP port e.g. 2525
EMAIL_USE_TLS=              # True or False
EMAIL_HOST_USER=            # get from Mailtrap inbox settings
EMAIL_HOST_PASSWORD=        # get from Mailtrap inbox settings
MAILTRAP_TOKEN=             # get from Mailtrap API tokens

# Frontend URLs
MAGIC_LINK_REDIRECT_URL=    # where to redirect after magic link click e.g. http://localhost:5173/#/auth/callback
LOGIN_REDIRECT_URL=         # alternative redirect URL e.g. http://localhost:5173/auth/callback
BACKEND_URL=                # backend base URL e.g. http://localhost:8000

# CORS & CSRF (comma separated origins)
CORS_ALLOWED_ORIGINS=       # e.g. http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=       # e.g. http://localhost:5173,http://127.0.0.1:5173