# Django core settings
DJANGO_SECRET_KEY=${DJANGO_SECRET_KEY}
DEBUG=${DEBUG}
ALLOWED_HOSTS=${ALLOWED_HOSTS}

# Database (Azure PostgreSQL)
DB_NAME=${DB_NAME}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT}

# Azure Blob Storage
USE_AZURE_BLOB_STORAGE=${USE_AZURE_BLOB_STORAGE}
AZURE_ACCOUNT_NAME=${AZURE_ACCOUNT_NAME}
AZURE_ACCOUNT_KEY=${AZURE_ACCOUNT_KEY}
AZURE_CONNECTION_STRING=${AZURE_CONNECTION_STRING}
AZURE_CONTAINER=${AZURE_CONTAINER}
AZURE_RESOURCE_CONTAINER=${AZURE_RESOURCE_CONTAINER}
AZURE_CHAT_CONTAINER=${AZURE_CHAT_CONTAINER}
AZURE_URL_EXPIRATION_SECS=${AZURE_URL_EXPIRATION_SECS}
AZURE_CUSTOM_DOMAIN=${AZURE_CUSTOM_DOMAIN}
RESOURCE_FILE_MAX_UPLOAD_SIZE=${RESOURCE_FILE_MAX_UPLOAD_SIZE}
CHAT_ATTACHMENT_MAX_UPLOAD_SIZE=${CHAT_ATTACHMENT_MAX_UPLOAD_SIZE}
RESOURCE_FILE_ALLOWED_EXTENSIONS=${RESOURCE_FILE_ALLOWED_EXTENSIONS}
RESOURCE_FILE_ALLOWED_MIME_TYPES=${RESOURCE_FILE_ALLOWED_MIME_TYPES}
CHAT_ATTACHMENT_ALLOWED_EXTENSIONS=${CHAT_ATTACHMENT_ALLOWED_EXTENSIONS}
CHAT_ATTACHMENT_ALLOWED_MIME_TYPES=${CHAT_ATTACHMENT_ALLOWED_MIME_TYPES}

# Email (Hostinger SMTP — port 465, implicit SSL)
EMAIL_HOST=${EMAIL_HOST}
EMAIL_PORT=${EMAIL_PORT}
EMAIL_USE_SSL=${EMAIL_USE_SSL}
EMAIL_HOST_USER=${EMAIL_HOST_USER}
EMAIL_HOST_PASSWORD=${EMAIL_HOST_PASSWORD}
DEFAULT_FROM_EMAIL=${DEFAULT_FROM_EMAIL}

# Frontend base URL (specific routes derived in settings.py)
FRONTEND_BASE_URL=${FRONTEND_BASE_URL}
ADMIN_FRONTEND_BASE_URL=${ADMIN_FRONTEND_BASE_URL}
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=${PASSWORD_RESET_TOKEN_EXPIRY_MINUTES}
BACKEND_URL=${BACKEND_URL}

# CORS & CSRF (comma separated origins)
CORS_ALLOWED_ORIGINS=${CORS_ALLOWED_ORIGINS}
CSRF_TRUSTED_ORIGINS=${CSRF_TRUSTED_ORIGINS}

# Chat Sanitizer
CHAT_SANITIZER_BLACKLIST=${CHAT_SANITIZER_BLACKLIST}
CHAT_SANITIZER_REPLACEMENT=${CHAT_SANITIZER_REPLACEMENT}

# RSVP reminder windows (hourly cron — defaults match standard 24h/1h)
RSVP_REMINDER_24H_HOURS_AHEAD=${RSVP_REMINDER_24H_HOURS_AHEAD}
RSVP_REMINDER_24H_WINDOW_HOURS=${RSVP_REMINDER_24H_WINDOW_HOURS}
RSVP_REMINDER_1H_HOURS_AHEAD=${RSVP_REMINDER_1H_HOURS_AHEAD}
RSVP_REMINDER_1H_WINDOW_HOURS=${RSVP_REMINDER_1H_WINDOW_HOURS}

# Shared secret for the external join-permission consent form webhook. Endpoint
# returns 503 when blank, mirroring RSVP_REMINDER_TOKEN's fail-loud contract.
JOIN_PERMISSION_WEBHOOK_TOKEN=${JOIN_PERMISSION_WEBHOOK_TOKEN}
