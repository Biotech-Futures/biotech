# Django core settings
DJANGO_SECRET_KEY=${DJANGO_SECRET_KEY}
DEBUG=${DEBUG}
ALLOWED_HOSTS=${ALLOWED_HOSTS}

# Trust X-Forwarded-For for rate-limit IP keys. REQUIRED in production:
# behind Azure Front Door / App Service ingress the WSGI socket peer is the
# load balancer, so every user shares the same client-IP key unless this is
# set. With it unset, the per-IP login throttle (apps/users/views.py
# PWD_LOGIN_PER_IP_LIMIT) locks out every legitimate user after 20 collective
# failed attempts across the whole platform. Leave unset for any deploy
# that's directly internet-reachable (the header would then be
# attacker-controlled).
TRUST_FORWARDED_FOR=${TRUST_FORWARDED_FOR}

# Database (Azure PostgreSQL)
DB_NAME=${DB_NAME}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT}

# Azure Blob Storage
USE_AZURE_BLOB_STORAGE=${USE_AZURE_BLOB_STORAGE}
AZURE_ACCOUNT_NAME=${AZURE_ACCOUNT_NAME}
AZURE_ACCOUNT_KEY=${AZURE_ACCOUNT_KEY}
AZURE_CONNECTION_STRING=${AZURE_CONNECTION_STRING}
AZURE_CONTAINER=${AZURE_CONTAINER}
AZURE_RESOURCE_CONTAINER=${AZURE_RESOURCE_CONTAINER}
AZURE_CHAT_CONTAINER=${AZURE_CHAT_CONTAINER}
AZURE_URL_EXPIRATION_SECS=${AZURE_URL_EXPIRATION_SECS}
AZURE_CUSTOM_DOMAIN=${AZURE_CUSTOM_DOMAIN}
RESOURCE_FILE_MAX_UPLOAD_SIZE=${RESOURCE_FILE_MAX_UPLOAD_SIZE}
CHAT_ATTACHMENT_MAX_UPLOAD_SIZE=${CHAT_ATTACHMENT_MAX_UPLOAD_SIZE}
RESOURCE_FILE_ALLOWED_EXTENSIONS=${RESOURCE_FILE_ALLOWED_EXTENSIONS}
RESOURCE_FILE_ALLOWED_MIME_TYPES=${RESOURCE_FILE_ALLOWED_MIME_TYPES}
CHAT_ATTACHMENT_ALLOWED_EXTENSIONS=${CHAT_ATTACHMENT_ALLOWED_EXTENSIONS}
CHAT_ATTACHMENT_ALLOWED_MIME_TYPES=${CHAT_ATTACHMENT_ALLOWED_MIME_TYPES}

# Email (Hostinger SMTP — port 465, implicit SSL)
EMAIL_HOST=${EMAIL_HOST}
EMAIL_PORT=${EMAIL_PORT}
EMAIL_USE_SSL=${EMAIL_USE_SSL}
EMAIL_HOST_USER=${EMAIL_HOST_USER}
EMAIL_HOST_PASSWORD=${EMAIL_HOST_PASSWORD}
# Sender mailbox only — brand name is pinned in settings.py (BRAND_NAME).
EMAIL_FROM_ADDRESS=${EMAIL_FROM_ADDRESS}

# Frontend / backend public base URLs (specific routes derived in settings.py).
# All three are REQUIRED outside DEBUG — settings.py raises ImproperlyConfigured
# at import time if any is unset, so a misconfigured deploy refuses to boot.
# No trailing slashes; include the scheme.
FRONTEND_BASE_URL=${FRONTEND_BASE_URL}
ADMIN_FRONTEND_BASE_URL=${ADMIN_FRONTEND_BASE_URL}
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=${PASSWORD_RESET_TOKEN_EXPIRY_MINUTES}
BACKEND_URL=${BACKEND_URL}

# CORS & CSRF (comma separated origins).
# Each entry MUST be a complete origin (scheme + host + optional port) with no
# trailing slash and no path. ``CORS_ALLOW_CREDENTIALS=True`` is hard-coded in
# settings.py, so wildcards are illegal here. A typo manifests in the browser
# as "blocked by CORS policy" because corsheaders silently drops malformed
# entries and never attaches Access-Control-Allow-Origin for them.
CORS_ALLOWED_ORIGINS=${CORS_ALLOWED_ORIGINS}
CSRF_TRUSTED_ORIGINS=${CSRF_TRUSTED_ORIGINS}

# Cache & Channels backend. Set to the Azure Cache for Redis connection
# string in production (rediss://...:6380/0). When unset, settings.py falls
# back to per-process LocMemCache + InMemoryChannelLayer, which is fine for
# `runserver` but breaks two things in a multi-worker deploy:
#   * rate-limit counters (login throttle, OTP send cap, password-reset cap)
#     become per-worker, so the effective limit is N_workers × the configured
#     value and which worker handles each request is random.
#   * Chat / websocket fan-out can't cross workers — different users connected
#     to different workers stop seeing each other's messages.
REDIS_URL=${REDIS_URL}

# Chat Sanitizer
CHAT_SANITIZER_BLACKLIST=${CHAT_SANITIZER_BLACKLIST}
CHAT_SANITIZER_REPLACEMENT=${CHAT_SANITIZER_REPLACEMENT}

# RSVP reminder windows (hourly cron — defaults match standard 24h/1h)
RSVP_REMINDER_24H_HOURS_AHEAD=${RSVP_REMINDER_24H_HOURS_AHEAD}
RSVP_REMINDER_24H_WINDOW_HOURS=${RSVP_REMINDER_24H_WINDOW_HOURS}
RSVP_REMINDER_1H_HOURS_AHEAD=${RSVP_REMINDER_1H_HOURS_AHEAD}
RSVP_REMINDER_1H_WINDOW_HOURS=${RSVP_REMINDER_1H_WINDOW_HOURS}

# Shared secret for POST /api/v1/events/admin/send-rsvp-reminders/ (and the
# legacy /events/v1/admin/send-rsvp-reminders/ alias). The hourly cron sends
# this token in the request body / header; the endpoint returns 503 when this
# is blank so a misconfigured deploy fails loud instead of silently exposing
# an unauthenticated trigger.
RSVP_REMINDER_TOKEN=${RSVP_REMINDER_TOKEN}

# Shared secret for the external join-permission consent form webhook. Endpoint
# returns 503 when blank, mirroring RSVP_REMINDER_TOKEN's fail-loud contract.
JOIN_PERMISSION_WEBHOOK_TOKEN=${JOIN_PERMISSION_WEBHOOK_TOKEN}

