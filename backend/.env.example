# Django core settings
DJANGO_SECRET_KEY=${DJANGO_SECRET_KEY}
DEBUG=${DEBUG}
ALLOWED_HOSTS=${ALLOWED_HOSTS}

# Database (Azure PostgreSQL)
DB_NAME=${DB_NAME}
DB_USER=${DB_USER}
DB_PASSWORD=${DB_PASSWORD}
DB_HOST=${DB_HOST}
DB_PORT=${DB_PORT}
DB_SSLMODE=${DB_SSLMODE}
DB_CONNECT_TIMEOUT=${DB_CONNECT_TIMEOUT}

# Azure Blob Storage
AZURE_ACCOUNT_NAME=${AZURE_ACCOUNT_NAME}
AZURE_ACCOUNT_KEY=${AZURE_ACCOUNT_KEY}
AZURE_CONTAINER=${AZURE_CONTAINER}

# Email (Mailtrap for development)
EMAIL_HOST=${EMAIL_HOST}
EMAIL_PORT=${EMAIL_PORT}
EMAIL_USE_TLS=${EMAIL_USE_TLS}
EMAIL_HOST_USER=${EMAIL_HOST_USER}
EMAIL_HOST_PASSWORD=${EMAIL_HOST_PASSWORD}
MAILTRAP_TOKEN=${MAILTRAP_TOKEN}

# Frontend URLs
MAGIC_LINK_REDIRECT_URL=${MAGIC_LINK_REDIRECT_URL}
LOGIN_REDIRECT_URL=${LOGIN_REDIRECT_URL}
BACKEND_URL=${BACKEND_URL}

# Redis / Channels / Celery
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=${REDIS_PORT}
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_USE_SSL=${REDIS_USE_SSL}
REDIS_CHANNEL_DB=${REDIS_CHANNEL_DB}
REDIS_CELERY_BROKER_DB=${REDIS_CELERY_BROKER_DB}
REDIS_CELERY_RESULT_DB=${REDIS_CELERY_RESULT_DB}
CHANNEL_REDIS_URL=${CHANNEL_REDIS_URL}
CELERY_BROKER_URL=${CELERY_BROKER_URL}
CELERY_RESULT_BACKEND=${CELERY_RESULT_BACKEND}

# CORS & CSRF (comma separated origins)
CORS_ALLOWED_ORIGINS=${CORS_ALLOWED_ORIGINS}
CSRF_TRUSTED_ORIGINS=${CSRF_TRUSTED_ORIGINS}